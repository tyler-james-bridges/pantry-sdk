---
import Base from "../../layouts/Base.astro";
import { listRecipes } from "../../lib/pantry-client";
import RecipeCard from "../../components/RecipeCard.astro";

const { recipes } = await listRecipes();
---

<Base title="Recipes | PantrySDK">
  <section class="header">
    <h1>Recipes</h1>
    <p>Free content for humans, programmable utilities for agents.</p>
    <a class="planner-link" href="/meal-planner">Open Meal Planner →</a>
  </section>

  <section class="grid">
    {recipes.map((r) => (
      <RecipeCard id={r.id} title={r.name} servings={r.servings} />
    ))}
  </section>
</Base>

<style>
  .header {
    margin-bottom: 18px;
  }

  .header h1 {
    margin: 0 0 6px;
  }

  .header p {
    margin: 0 0 10px;
    color: #4b5563;
  }

  .planner-link {
    text-decoration: none;
    font-weight: 600;
    color: #9a3412;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 14px;
  }
</style>
