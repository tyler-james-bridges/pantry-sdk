---
import Base from "../../layouts/Base.astro";
import { listRecipes } from "../../lib/pantry-client";
import RecipeCard from "../../components/RecipeCard.astro";

const fallbackRecipes = [
  { id: "garlic-pasta", name: "Creamy Garlic Pasta", servings: 4 },
  { id: "quinoa-bowl", name: "Mediterranean Quinoa Bowl", servings: 2 },
  { id: "chocolate-cookies", name: "Chocolate Chip Cookies", servings: 12 },
  { id: "grilled-salmon", name: "Grilled Salmon", servings: 4 },
  { id: "thai-curry", name: "Thai Green Curry", servings: 6 },
  { id: "caprese-salad", name: "Fresh Caprese Salad", servings: 4 },
];

let recipes = fallbackRecipes;
try {
  const data = await listRecipes();
  if (data?.recipes?.length) recipes = data.recipes;
} catch {
  // Vercel static build / local build fallback
}
---

<Base title="Recipes | PantrySDK">
  <section class="header">
    <h1>Cookie Feed</h1>
    <p>Pin-inspired recipe discovery with built-in planning utilities.</p>

    <div class="search-row">
      <input type="text" value="chocolate chip cookies" readonly />
      <a class="planner-link" href="/meal-planner">Plan meals</a>
    </div>

    <div class="chips">
      <span>Cookies</span><span>Brown Butter</span><span>Soft + Chewy</span><span>Holiday</span><span>Beginner</span>
    </div>
  </section>

  <section class="masonry">
    {recipes.map((r) => (
      <RecipeCard id={r.id} title={r.name} servings={r.servings} />
    ))}
  </section>
</Base>

<style>
  :global(body) {
    background: #f6f1ea;
  }

  .header {
    margin-bottom: 16px;
  }

  .header h1 {
    margin: 0 0 6px;
    font-size: 2.2rem;
    letter-spacing: -0.02em;
  }

  .header p {
    margin: 0 0 12px;
    color: #5b4b3b;
  }

  .search-row {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 10px;
  }

  .search-row input {
    border: 1px solid #e4d4c2;
    background: #fff;
    border-radius: 999px;
    padding: 11px 14px;
    min-width: 280px;
    color: #6b5b4b;
  }

  .planner-link {
    text-decoration: none;
    font-weight: 700;
    color: #fff;
    background: #111827;
    border-radius: 999px;
    padding: 10px 14px;
  }

  .chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .chips span {
    font-size: 0.75rem;
    padding: 5px 11px;
    border-radius: 999px;
    border: 1px solid #e7d8c7;
    background: #fffaf5;
    color: #6b4e33;
  }

  .masonry {
    column-count: 1;
    column-gap: 16px;
  }

  @media (min-width: 720px) {
    .masonry { column-count: 2; }
  }

  @media (min-width: 1024px) {
    .masonry { column-count: 4; }
  }
</style>
