---
import Base from "../../layouts/Base.astro";
import { listRecipes } from "../../lib/pantry-client";
import RecipeCard from "../../components/RecipeCard.astro";

const { recipes } = await listRecipes();
---

<Base title="Recipes | PantrySDK">
  <section class="header">
    <h1>Discover Recipes</h1>
    <p>Scroll, save, and turn content into actionable meal planning.</p>
    <div class="row">
      <a class="planner-link" href="/meal-planner">Open Meal Planner →</a>
      <div class="chips">
        <span>Dessert</span><span>Dinner</span><span>High Protein</span><span>Quick</span>
      </div>
    </div>
  </section>

  <section class="masonry">
    {recipes.map((r) => (
      <RecipeCard id={r.id} title={r.name} servings={r.servings} />
    ))}
  </section>
</Base>

<style>
  :global(body) {
    background: #faf7f2;
  }

  .header {
    margin-bottom: 14px;
  }

  .header h1 {
    margin: 0 0 6px;
    font-size: 2rem;
  }

  .header p {
    margin: 0 0 10px;
    color: #5b4b3b;
  }

  .row {
    display: flex;
    align-items: center;
    gap: 12px;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .planner-link {
    text-decoration: none;
    font-weight: 700;
    color: #9a3412;
  }

  .chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .chips span {
    font-size: 0.75rem;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid #ecdcc7;
    background: #fff;
    color: #6b4e33;
  }

  .masonry {
    column-count: 1;
    column-gap: 14px;
  }

  @media (min-width: 700px) {
    .masonry { column-count: 2; }
  }

  @media (min-width: 980px) {
    .masonry { column-count: 3; }
  }

  @media (min-width: 1280px) {
    .masonry { column-count: 4; }
  }
</style>
