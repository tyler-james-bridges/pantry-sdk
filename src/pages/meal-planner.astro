---
import Base from "../layouts/Base.astro";
import PriceBadge from "../components/PriceBadge.astro";

// Static sample data instead of API calls
const recipes = [
  { id: "garlic-pasta", name: "Creamy Garlic Pasta", servings: 4 },
  { id: "quinoa-bowl", name: "Mediterranean Quinoa Bowl", servings: 2 },
  { id: "chocolate-cookies", name: "Chocolate Chip Cookies", servings: 12 },
  { id: "grilled-salmon", name: "Grilled Salmon", servings: 4 },
  { id: "thai-curry", name: "Thai Green Curry", servings: 6 },
  { id: "caprese-salad", name: "Fresh Caprese Salad", servings: 4 }
];

const selected = Astro.url.searchParams.getAll("r");
const servingsMap: Record<string, number> = {};
for (const r of recipes) {
  const s = Number(Astro.url.searchParams.get(`s_${r.id}`) || r.servings);
  servingsMap[r.id] = Number.isFinite(s) && s > 0 ? s : r.servings;
}

// Sample result for demo purposes
let result = null;
if (selected.length > 0) {
  result = {
    mealPlan: selected.map(id => {
      const recipe = recipes.find(r => r.id === id);
      return {
        recipeId: id,
        recipeName: recipe?.name || "Unknown Recipe",
        servings: servingsMap[id] || recipe?.servings || 1
      };
    }),
    shoppingList: [
      { amount: "2", unit: "lbs", name: "pasta" },
      { amount: "1", unit: "head", name: "garlic" },
      { amount: "1", unit: "pint", name: "heavy cream" },
      { amount: "1", unit: "cup", name: "parmesan cheese" },
      { amount: "3", unit: "tbsp", name: "olive oil" }
    ],
    prepSummary: {
      totalUniqueIngredients: 5
    }
  };
}
---

<Base title="Meal Planner | Pantry">
  <div class="container">
    <section class="header">
      <h1>🗓️ Meal Planner</h1>
      <p>Build a weekly plan and auto-generate a shopping list.</p>
      <PriceBadge price="$0.03" label="Generate Plan" />
    </section>

    <form method="GET" class="planner-form">
      <section class="cards">
        {recipes.map((r) => (
          <label class={`recipe-option ${selected.includes(r.id) ? 'selected' : ''}`}>
            <div class="thumb"></div>
            <div class="meta">
              <input type="checkbox" name="r" value={r.id} checked={selected.includes(r.id)} />
              <strong>{r.name}</strong>
              <span>{r.servings} default servings</span>
            </div>
            <div class="servings">
              <span>Servings</span>
              <input
                type="number"
                min="1"
                name={`s_${r.id}`}
                value={servingsMap[r.id]}
              />
            </div>
          </label>
        ))}
      </section>

      <button type="submit" class="submit-btn">Generate Meal Plan</button>
    </form>

    {result && (
      <section class="result">
        <h2>📋 Your Meal Plan</h2>
        <ul>
          {result.mealPlan.map((m) => (
            <li><a href={`/recipes/${m.recipeId}?servings=${m.servings}`}>{m.recipeName}</a> — {m.servings} servings</li>
          ))}
        </ul>

        <h2>🛒 Shopping List ({result.prepSummary.totalUniqueIngredients} items)</h2>
        <ul>
          {result.shoppingList.map((i) => (
            <li><strong>{i.amount} {i.unit}</strong> {i.name}</li>
          ))}
        </ul>
      </section>
    )}
  </div>
</Base>

<style>
  :global(body) { 
    background: #f6f1ea; 
  }

  .header { 
    margin-bottom: 2rem;
    text-align: center;
  }
  
  .header h1 { 
    margin: 0 0 0.5rem; 
    font-size: 2.5rem;
    color: #333;
  }
  
  .header p { 
    margin: 0 0 1rem; 
    color: #5b4b3b; 
    font-size: 1.1rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .recipe-option {
    border: 2px solid #e8dccd;
    border-radius: 16px;
    background: #fff;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.2s;
  }

  .recipe-option:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  }

  .recipe-option.selected {
    border-color: #ff6b6b;
    box-shadow: 0 0 0 3px rgba(255, 107, 107, 0.15);
  }

  .thumb {
    height: 120px;
    background: linear-gradient(135deg, #f8ddc2, #ebb082);
  }

  .meta {
    padding: 1rem;
    display: grid;
    gap: 0.5rem;
  }

  .meta input[type="checkbox"] {
    margin-bottom: 0.5rem;
  }

  .meta strong {
    font-size: 1.1rem;
    color: #333;
  }

  .meta span { 
    font-size: 0.9rem; 
    color: #6b5b4b; 
  }

  .servings {
    border-top: 1px solid #f0e7db;
    padding: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .servings span {
    font-weight: 600;
    color: #333;
  }

  .servings input {
    width: 80px;
    border: 2px solid #e8dccd;
    border-radius: 8px;
    padding: 0.5rem;
    font-size: 1rem;
  }

  .submit-btn {
    border: 0;
    border-radius: 50px;
    padding: 1rem 2rem;
    background: #ff6b6b;
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    cursor: pointer;
    display: block;
    margin: 0 auto;
    transition: all 0.2s;
  }

  .submit-btn:hover {
    background: #ff5252;
    transform: translateY(-2px);
  }

  .result {
    margin-top: 3rem;
    background: #fff;
    border: 2px solid #e8dccd;
    border-radius: 16px;
    padding: 2rem;
  }

  .result h2 {
    color: #ff6b6b;
    margin-bottom: 1rem;
  }

  .result ul {
    list-style: none;
    padding: 0;
  }

  .result li {
    padding: 0.5rem 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .result li:last-child {
    border-bottom: none;
  }

  .result a {
    color: #ff6b6b;
    text-decoration: none;
    font-weight: 600;
  }

  .result a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .cards {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    .header h1 {
      font-size: 2rem;
    }
  }
</style>