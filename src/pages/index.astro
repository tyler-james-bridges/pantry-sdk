---
import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import RecipeCard from "../components/RecipeCard.astro";

// Try to get recipes from EmDash, fallback to sample data if not available
let recipes = [];
try {
  const { entries, cacheHint } = await getEmDashCollection("recipes", {
    orderBy: { created_at: "desc" },
  });
  Astro.cache.set(cacheHint);
  recipes = entries;
} catch (error) {
  console.warn("EmDash not available, using sample data:", error.message);
  // Fallback sample data
  recipes = [
    {
      id: "garlic-pasta",
      data: {
        title: "Creamy Garlic Pasta",
        description: "Rich and creamy pasta with roasted garlic and herbs",
        cook_time: "25 min",
        difficulty: "Easy",
        rating: 4.8
      }
    },
    {
      id: "quinoa-bowl",
      data: {
        title: "Mediterranean Quinoa Bowl",
        description: "Healthy quinoa with fresh vegetables and feta cheese",
        cook_time: "20 min",
        difficulty: "Easy", 
        rating: 4.6
      }
    },
    {
      id: "thai-curry",
      data: {
        title: "Thai Green Curry",
        description: "Spicy and aromatic curry with fresh vegetables",
        cook_time: "35 min",
        difficulty: "Hard",
        rating: 4.5
      }
    }
  ];
}
---

<Base title="Pantry - Recipe Collection">
  <div class="container">
    <header class="hero">
      <h1>🍳 Pantry</h1>
      <p>Discover delicious recipes for every occasion</p>
      <div class="hero-actions">
        <a href="/recipes" class="btn btn-primary">Browse Recipes</a>
        <a href="/meal-planner" class="btn btn-secondary">Plan Meals</a>
        <a href="/_emdash/admin" class="btn btn-admin">Admin Panel</a>
      </div>
    </header>

    <section class="featured-recipes">
      <h2>Featured Recipes</h2>
      {recipes.length === 0 ? (
        <div class="empty-state">
          <p>No recipes yet! <a href="/_emdash/admin/content/recipes/new">Create your first recipe</a> in the admin panel.</p>
        </div>
      ) : (
        <div class="recipe-grid">
          {recipes.map(recipe => (
            <RecipeCard 
              id={recipe.id}
              title={recipe.data.title}
              description={recipe.data.description}
              cookTime={recipe.data.cook_time}
              difficulty={recipe.data.difficulty}
              rating={recipe.data.rating}
            />
          ))}
        </div>
      )}
    </section>
  </div>
</Base>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .hero {
    text-align: center;
    padding: 60px 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 20px;
    margin-bottom: 60px;
  }

  .hero h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .hero p {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 12px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-primary {
    background: #ff6b6b;
    color: white;
  }

  .btn-primary:hover {
    background: #ff5252;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.2);
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.3);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: translateY(-2px);
  }

  .btn-admin {
    background: rgba(255, 255, 255, 0.1);
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.2);
  }

  .btn-admin:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .empty-state a {
    color: #ff6b6b;
    text-decoration: none;
    font-weight: 600;
  }

  .empty-state a:hover {
    text-decoration: underline;
  }

  .featured-recipes h2 {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 2.5rem;
    color: #333;
  }

  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2.5rem;
    }
    
    .recipe-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1.5rem;
    }
  }
</style>