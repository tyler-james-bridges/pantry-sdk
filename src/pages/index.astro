---
import Base from "../layouts/Base.astro";
import RecipeCard from "../components/RecipeCard.astro";

// Sample recipe data (will be replaced with EmDash CMS when deployed to Cloudflare)
const sampleRecipes = [
  {
    id: "garlic-pasta",
    data: {
      title: "Creamy Garlic Pasta",
      description: "Rich and creamy pasta with roasted garlic and herbs",
      cook_time: "25 min",
      difficulty: "Easy",
      rating: 4.8
    }
  },
  {
    id: "quinoa-bowl",
    data: {
      title: "Mediterranean Quinoa Bowl",
      description: "Healthy quinoa with fresh vegetables and feta cheese",
      cook_time: "20 min",
      difficulty: "Easy", 
      rating: 4.6
    }
  },
  {
    id: "chocolate-cookies",
    data: {
      title: "Chocolate Chip Cookies",
      description: "Classic homemade cookies with melty chocolate chips",
      cook_time: "30 min",
      difficulty: "Medium",
      rating: 4.9
    }
  },
  {
    id: "grilled-salmon",
    data: {
      title: "Grilled Salmon",
      description: "Perfectly grilled salmon with lemon and herbs",
      cook_time: "15 min",
      difficulty: "Medium",
      rating: 4.7
    }
  },
  {
    id: "thai-curry",
    data: {
      title: "Thai Green Curry",
      description: "Spicy and aromatic curry with fresh vegetables",
      cook_time: "35 min",
      difficulty: "Hard",
      rating: 4.5
    }
  },
  {
    id: "caprese-salad",
    data: {
      title: "Fresh Caprese Salad",
      description: "Simple salad with tomatoes, mozzarella, and basil",
      cook_time: "10 min",
      difficulty: "Easy",
      rating: 4.4
    }
  }
];
---

<Base title="🍳 Pantry - Recipe Collection">
  <div class="container">
    <header class="hero">
      <h1>🍳 Pantry</h1>
      <p>Discover delicious recipes for every occasion</p>
      <p class="powered-by">Ready for EmDash CMS + Cloudflare deployment</p>
      <div class="hero-actions">
        <a href="/recipes" class="btn btn-primary">Browse Recipes</a>
        <a href="/meal-planner" class="btn btn-secondary">Plan Meals</a>
      </div>
    </header>

    <section class="featured-recipes">
      <h2>Featured Recipes</h2>
      <p class="demo-notice">🚧 Demo mode - showing sample recipes. Deploy to Cloudflare to enable full EmDash CMS.</p>
      <div class="recipe-grid">
        {sampleRecipes.map(recipe => (
          <RecipeCard 
            id={recipe.id}
            title={recipe.data.title}
            description={recipe.data.description}
            cookTime={recipe.data.cook_time}
            difficulty={recipe.data.difficulty}
            rating={recipe.data.rating}
          />
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .hero {
    text-align: center;
    padding: 60px 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 20px;
    margin-bottom: 60px;
  }

  .hero h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .hero p {
    font-size: 1.2rem;
    margin-bottom: 1rem;
    opacity: 0.9;
  }

  .powered-by {
    font-size: 0.9rem;
    opacity: 0.8;
    margin-bottom: 2rem !important;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 12px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-primary {
    background: #ff6b6b;
    color: white;
  }

  .btn-primary:hover {
    background: #ff5252;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.2);
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.3);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: translateY(-2px);
  }

  .featured-recipes h2 {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 2.5rem;
    color: #333;
  }

  .recipe-grid {
    column-count: auto;
    column-width: 300px;
    column-gap: 2rem;
    margin-bottom: 4rem;
  }

  .demo-notice {
    text-align: center;
    padding: 1rem;
    background: #fff3cd;
    border: 1px solid #ffeaa7;
    border-radius: 8px;
    color: #856404;
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2.5rem;
    }
    
    .recipe-grid {
      column-count: 1;
      column-gap: 1.5rem;
    }
  }
</style>