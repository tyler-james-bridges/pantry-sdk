---
interface Props {
  id: string;
  title: string;
  description?: string;
  cookTime?: string;
  difficulty?: string;
  rating?: number;
  servings?: number;
}

const { id, title, description = '', cookTime = '30 min', difficulty = 'Medium', rating, servings } = Astro.props;
const seed = id.split('').reduce((a, c) => a + c.charCodeAt(0), 0);
const heights = [260, 320, 380, 440];
const heroHeight = heights[seed % heights.length];
const palettes = [
  'linear-gradient(150deg, #f7e5cf 0%, #f9cfa5 45%, #e8a46c 100%)',
  'linear-gradient(150deg, #f9ead9 0%, #f4c4a8 45%, #cf8862 100%)',
  'linear-gradient(150deg, #fff2e2 0%, #f9d2bb 45%, #d49373 100%)'
];
const heroBg = palettes[seed % palettes.length];
---

<a class="recipe-card" href={`/recipes/${id}`}>
  <div class="recipe-card__hero" style={`height:${heroHeight}px; background:${heroBg}`}>
    <button class="save-btn" type="button" aria-label="Save recipe">Save</button>
    <div class="overlay"></div>
    <div class="hero-label">{title.split(' ').slice(0, 3).join(' ')}</div>
  </div>

  <div class="recipe-card__content">
    <h3>{title}</h3>
    <p class="description">{description}</p>
    <div class="recipe-meta">
      <span class="time">⏱️ {cookTime}</span>
      <span class="difficulty">{difficulty}</span>
      {rating && <span class="rating">⭐ {rating}</span>}
      {servings && <span class="servings">{servings} servings</span>}
    </div>
  </div>
</a>

<style>
  .recipe-card {
    display: inline-block;
    width: 100%;
    text-decoration: none;
    color: inherit;
    border: 1px solid #e8dccd;
    border-radius: 22px;
    background: #fff;
    overflow: hidden;
    margin-bottom: 16px;
    transition: transform 160ms ease, box-shadow 160ms ease;
    break-inside: avoid;
  }

  .recipe-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 32px rgba(42, 25, 7, 0.14);
  }

  .recipe-card__hero {
    position: relative;
    display: flex;
    align-items: end;
    padding: 14px;
    isolation: isolate;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(51, 30, 12, 0.42), rgba(0,0,0,0));
    z-index: 1;
  }

  .hero-label {
    position: relative;
    z-index: 2;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(0,0,0,0.26);
    border-radius: 999px;
    padding: 4px 10px;
    backdrop-filter: blur(3px);
  }

  .save-btn {
    position: absolute;
    z-index: 2;
    top: 10px;
    right: 10px;
    border: 0;
    background: #e60023;
    color: white;
    font-weight: 700;
    min-width: 56px;
    height: 34px;
    border-radius: 999px;
    font-size: 0.78rem;
    cursor: pointer;
  }

  .recipe-card__content {
    padding: 14px;
  }

  .recipe-card h3 {
    margin: 0 0 6px;
    font-size: 1.04rem;
    line-height: 1.3;
  }

  .description {
    margin: 0 0 10px;
    color: #6b5b4b;
    font-size: 0.88rem;
    line-height: 1.4;
  }

  .recipe-meta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  .recipe-meta span {
    font-size: 0.8rem;
    color: #8a7968;
  }

  .time {
    background: #f0f8f0;
    padding: 3px 8px;
    border-radius: 12px;
  }

  .difficulty {
    background: #fff0e6;
    padding: 3px 8px;
    border-radius: 12px;
  }

  .rating {
    font-weight: 600;
  }
</style>
